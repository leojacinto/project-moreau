{
  "name": "x_snc_virgil_ontology_node",
  "label": "Ontology Node",
  "plural": "Ontology Nodes",
  "extends": "",
  "fields": [
    {"name": "node_id",       "label": "Node ID",          "type": "string",  "max_length": 40,   "unique": true, "mandatory": true},
    {"name": "name",           "label": "Name",             "type": "string",  "max_length": 200,  "mandatory": true},
    {"name": "node_type",      "label": "Node Type",        "type": "choice",  "max_length": 40,
      "choices": ["platform", "data", "table", "product", "module", "orchestration", "ui", "external"]},
    {"name": "aliases",        "label": "Aliases (JSON)",    "type": "string",  "max_length": 2000},
    {"name": "tables",         "label": "Tables (JSON)",     "type": "string",  "max_length": 2000,
      "comment": "JSON array of SN table names used for activity detection"},
    {"name": "plugins",        "label": "Plugins (JSON)",    "type": "string",  "max_length": 2000,
      "comment": "JSON array of plugin IDs used for presence detection"},
    {"name": "layer",          "label": "Layer",             "type": "choice",  "max_length": 40,
      "choices": ["platform", "data", "application", "orchestration", "ui", "external"]},
    {"name": "it4it_streams",  "label": "IT4IT Streams (JSON)", "type": "string", "max_length": 200,
      "comment": "JSON array, e.g. [\"R2F\",\"D2C\"]"},
    {"name": "active",         "label": "Active",           "type": "boolean", "default_value": "true"},
    {"name": "order",          "label": "Order",            "type": "integer", "default_value": "100"}
  ]
}
